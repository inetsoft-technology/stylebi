            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/em/src/favicon.ico",
              "projects/em/src/assets"
            ],
            "styles": [
              "projects/em/src/styles.scss"
            ],
            "scripts": [
              "node_modules/stompjs/lib/stomp.js",
              "node_modules/acorn/dist/acorn.js",
              "node_modules/acorn-loose/dist/acorn-loose.js",
              "node_modules/acorn-walk/dist/walk.js",
              "node_modules/tern/lib/signal.js",
              "node_modules/tern/lib/tern.js",
              "node_modules/tern/lib/def.js",
              "node_modules/tern/lib/comment.js",
              "node_modules/tern/lib/infer.js",
              "node_modules/@inetsoft-technology/ai-assistant/dist/web-component/ai-assistant.umd.js",
              "node_modules/@inetsoft-technology/stylebi-wiz-portal/dist/web-component/stylebi-wiz-portal.umd.cjs"
            ],
            "browser": "projects/em/src/main.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning" : "6kb"
                }
              ],
              "optimization": true,
              "outputHashing": "bundles",
              "sourceMap": false,
              "namedChunks": false
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "em:build:production"
            },
            "development": {
              "buildTarget": "em:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "em:build"
          }
        },
        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {
            "ci": true,
            "maxWorkers": 4,
            "silent": true,
            "zoneless": false,
            "reporters": [
              "default",
              "jest-junit"
            ],
            "setupFiles": [
              "jest-canvas-mock"
            ],
            "testPathIgnorePatterns": [
              "\\.tl\\.spec\\.ts$"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/em/**/*.ts",
              "projects/em/**/*.html"
            ]
          }
        }
      }
    },
    "elements": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/portal",
      "sourceRoot": "projects/portal/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "target/generated-resources/ng/inetsoft/web/resources/elements",
              "browser": ""
            },
            "index": "projects/portal/src/index.html",
            "allowedCommonJsDependencies": [
              "codemirror",
              "lodash",
              "dayjs",
              "interactjs",
              "sockjs-client",
              "jsplumb"
            ],
            "polyfills": [
              "zone.js",
              "@angular/localize/init",
              "projects/portal/src/polyfills.ts"
            ],
            "tsConfig": "projects/portal/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/portal/src/favicon.ico",
              "projects/portal/src/assets",
              {
                "glob": "**/*",
                "input": "node_modules/roboto-fontface/fonts/roboto",
                "output": "assets/roboto"
              }
            ],
            "styles": [
              "projects/portal/src/styles.scss"
            ],
            "scripts": [
              "node_modules/stompjs/lib/stomp.js",
              "node_modules/acorn/dist/acorn.js",
              "node_modules/acorn-loose/dist/acorn-loose.js",
              "node_modules/acorn-walk/dist/walk.js",
              "node_modules/tern/lib/signal.js",
              "node_modules/tern/lib/tern.js",
              "node_modules/tern/lib/def.js",
              "node_modules/tern/lib/comment.js",
              "node_modules/tern/lib/infer.js",
              "node_modules/@inetsoft-technology/ai-assistant/dist/web-component/ai-assistant.umd.js"
            ],
            "browser": "projects/portal/src/main-elements.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning" : "6kb"
                }
              ],
              "optimization": true,
              "outputHashing": "bundles",
              "sourceMap": false,
              "namedChunks": false
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "elements:build:production"
            },
            "development": {
              "buildTarget": "elements:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "elements:build"
          }
        }
      }
    },
    "viewer-element": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/portal",
      "sourceRoot": "projects/portal/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "target/generated-resources/ng/inetsoft/web/resources/viewer-element",
              "browser": ""
            },
            "index": "projects/portal/src/index.html",
            "allowedCommonJsDependencies": [
              "codemirror",
              "lodash",
              "dayjs",
              "interactjs",
              "sockjs-client",
              "jsplumb"
            ],
            "polyfills": [
              "zone.js",
              "@angular/localize/init",
              "projects/portal/src/polyfills.ts"
            ],
            "tsConfig": "projects/portal/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/portal/src/favicon.ico",
              "projects/portal/src/assets",
              {
                "glob": "**/*",
                "input": "node_modules/roboto-fontface/fonts/roboto",
                "output": "assets/roboto"
              }
            ],
            "styles": [
              "projects/portal/src/styles.scss"
            ],
            "scripts": [
              "node_modules/stompjs/lib/stomp.js",
              "node_modules/acorn/dist/acorn.js",
              "node_modules/acorn-loose/dist/acorn-loose.js",
              "node_modules/acorn-walk/dist/walk.js",
              "node_modules/tern/lib/signal.js",
              "node_modules/tern/lib/tern.js",
              "node_modules/tern/lib/def.js",
              "node_modules/tern/lib/comment.js",
              "node_modules/tern/lib/infer.js",
              "node_modules/@inetsoft-technology/ai-assistant/dist/web-component/ai-assistant.umd.js"
            ],
            "browser": "projects/portal/src/main-viewer-element.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning" : "6kb"
                }
              ],
              "optimization": true,
              "outputHashing": "bundles",
              "sourceMap": false,
              "namedChunks": false
            },
            "development": {
              "optimization": false,
