{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "cli": {
    "schematicCollections": [
      "@angular-eslint/schematics"
    ],
    "analytics": false
  },
  "projects": {
    "portal": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/portal",
      "sourceRoot": "projects/portal/src",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "target/generated-resources/ng/inetsoft/web/resources/app",
              "browser": ""
            },
            "index": "projects/portal/src/index.html",
            "allowedCommonJsDependencies": [
              "codemirror",
              "lodash",
              "dayjs"
            ],
            "polyfills": [
              "zone.js",
              "@angular/localize/init",
              "projects/portal/src/polyfills.ts"
            ],
            "tsConfig": "projects/portal/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/portal/src/favicon.ico",
              "projects/portal/src/assets"
            ],
            "styles": [
              "projects/portal/src/styles.scss"
            ],
            "scripts": [
              "node_modules/stompjs/lib/stomp.js",
              "node_modules/acorn/dist/acorn.js",
              "node_modules/acorn-loose/dist/acorn-loose.js",
              "node_modules/acorn-walk/dist/walk.js",
              "node_modules/tern/lib/signal.js",
              "node_modules/tern/lib/tern.js",
              "node_modules/tern/lib/def.js",
              "node_modules/tern/lib/comment.js",
              "node_modules/tern/lib/infer.js",
              "node_modules/@inetsoft-technology/ai-assistant/dist/web-component/ai-assistant.umd.js",
              "node_modules/@inetsoft-technology/stylebi-wiz-portal/dist/web-component/stylebi-wiz-portal.umd.cjs",
              "node_modules/@inetsoft-technology/stylebi-wiz-ai-chat/dist/web-component/stylebi-wiz-ai-chat.umd.cjs"
            ],
            "browser": "projects/portal/src/main.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "anyComponentStyle",
                  "maximumWarning" : "6kb"
                }
              ],
              "optimization": true,
              "outputHashing": "bundles",
              "sourceMap": false,
              "namedChunks": false
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "portal:build:production"
            },
            "development": {
              "buildTarget": "portal:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "portal:build"
          }
        },
        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {
            "ci": true,
            "maxWorkers": 4,
            "silent": true,
            "zoneless": false,
            "reporters": [
              "default",
              "jest-junit"
            ],
            "setupFiles": [
              "jest-canvas-mock",
              "<rootDir>/projects/portal/src/jest-setup.ts"
            ],
            "testPathIgnorePatterns": [
              "\\.tl\\.spec\\.ts$"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/portal/**/*.ts",
              "projects/portal/**/*.html",
              "projects/shared/**/*.ts",
              "projects/shared/**/*.html"
            ]
          }
        }
      }
    },
    "em": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/em",
      "sourceRoot": "projects/em/src",
      "prefix": "em",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "target/generated-resources/ng/inetsoft/web/resources/em",
              "browser": ""
            },
            "index": "projects/em/src/index.html",
            "allowedCommonJsDependencies": [
              "codemirror",
              "lodash",
              "dayjs"
            ],
            "polyfills": [
              "zone.js",
              "@angular/localize/init",
              "projects/em/src/polyfills.ts"
